# ---------------------------------------------------------------------------
# Contact form email (Resend)  —  copy this file to .env.local and fill it in.
# .env.local is gitignored, so your key is never committed.
# ---------------------------------------------------------------------------

# 1. Create a free account at https://resend.com
# 2. Generate an API key at https://resend.com/api-keys
# 3. Paste it below.
RESEND_API_KEY=

# Where contact-form messages are delivered.
CONTACT_TO=sajidhsaz@gmail.com

# The "from" address.
# For quick testing you can use Resend's shared sender below as-is — it will
# deliver to the CONTACT_TO inbox without any domain setup.
# For production, verify your own domain in Resend and use something like:
#   CONTACT_FROM="Sajidh Ahamed <hello@yourdomain.com>"
CONTACT_FROM="Portfolio <onboarding@resend.dev>"
